#include <dt-bindings/zmk/matrix_transform.h>

&gpio0 {
  status = "okay";
};

zephyr_udc0: &usbd {
  status = "okay";
};

&pinctrl {
  i2c0_default: i2c0_default {
    group1 {
      pinmux = <I2C0_SDA_P12>, <I2C0_SCL_P13>;
      input-enable;
      input-schmitt-enable;
    };
  };
};

&i2c0 {
  status = "okay";
  pinctrl-0 = <&i2c0_default>;
  pinctrl-names = "default";
  clock-frequency = <I2C_BITRATE_STANDARD>;
};

/ {
  chosen {
    zmk,kscan = &kscan0;
    zmk,matrix_transform = &default_transform;
  };

  default_transform: keymap_transform_0 {
    compatible = "zmk,matrix-transform";
    columns = <36>;
    rows = <1>;
    map = <
      RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)     RC(0,22) RC(0,21) RC(0,20) RC(0,19) RC(0,18)
      RC(0,5)  RC(0,6)  RC(0,7)  RC(0,8)  RC(0,9)     RC(0,27) RC(0,26) RC(0,25) RC(0,24) RC(0,23)
      RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14)    RC(0,32) RC(0,31) RC(0,30) RC(0,29) RC(0,28)
                        RC(0,15) RC(0,16) RC(0,17)    RC(0,35) RC(0,34) RC(0,33)
    >;
  };

  kscan0: kscan {
    compatible = "zmk,kscan-gpio-direct";
    input-gpios
      = <&gpio0 4 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 3 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 2  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 1  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 0 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 5  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 6  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 7 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 8 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 9  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 10  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 19  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 20  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 18  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 26  (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 27 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 28 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      , <&gpio0 29 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>
      ;
  };

  wired_split {
    compatible = "zmk,wired-split";
    device = <&pio0>;
  };
};
